generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Folder {
  id        String    @id @default(uuid())
  name      String
  userId    String    @default("default-user")
  projects  Project[]
  createdAt DateTime  @default(now())

  @@map("folder")
}

model Project {
  id         String   @id @default(uuid())
  name       String
  folderId   String
  folder     Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  userId     String   @default("default-user")
  tasks      Task[]
  auditLogs  AuditLog[]
  hourlyRate Float?
  fixedPrice Float?
  createdAt  DateTime @default(now())

  @@map("project")
}


model Task {
  id              String      @id @default(uuid())
  projectId       String
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  status          String      @default("todo")
  accumulatedTime Int         @default(0)
  timerStartedAt  DateTime?
  files           String?
  timeEntries     TimeEntry[]
  createdAt       DateTime    @default(now())
  deletedAt       DateTime?

  @@map("task")
}

model TimeEntry {
  id          String   @id @default(uuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  description String?
  duration    Int      // in seconds
  startTime   DateTime
  endTime     DateTime
  createdAt   DateTime @default(now())

  @@map("time_entry")
}

model AuditLog {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  action      String   // e.g., "CREATE_TASK", "MOVE_TASK", "ADD_TIME"
  details     String   // JSON or text description
  createdAt   DateTime @default(now())

  @@map("audit_log")
}

